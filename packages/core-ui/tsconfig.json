{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "noEmit": true,
    "paths": {
      "@/components": ["./src"],
      "@/components/*": ["./src/*"],
      "@/lib/compass-logic": ["../qbscript/src"],
      "@/lib/compass-logic/*": ["../qbscript/src/*"],
      "@/lib/cloud": ["../cloud/src"],
      "@/lib/cloud/*": ["../cloud/src/*"],
      "@/lib/campaign-play": ["../runtime/src"],
      "@/lib/campaign-play/*": ["../runtime/src/*"],
      "@/*": ["../core-engine/src/*"]
    },
    "types": ["vite/client", "cypress", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
