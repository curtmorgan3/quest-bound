{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "noEmit": true,
    "paths": {
      "@/pages/characters": ["../runtime/src/pages/characters"],
      "@/pages/characters/*": ["../runtime/src/pages/characters/*"],
      "@/pages/campaigns": ["../runtime/src/pages/campaigns"],
      "@/pages/campaigns/*": ["../runtime/src/pages/campaigns/*"],
      "@/pages/dice": ["../runtime/src/pages/dice"],
      "@/pages/dice/*": ["../runtime/src/pages/dice/*"],
      "@/lib/cloud": ["./src"],
      "@/lib/cloud/*": ["./src/*"],
      "@/lib/campaign-play": ["../runtime/src"],
      "@/lib/campaign-play/*": ["../runtime/src/*"],
      "@/lib/compass-api/hooks": ["../local-db/src/api-hooks"],
      "@/lib/compass-api/hooks/*": ["../local-db/src/api-hooks/*"],
      "@/components": ["../core-ui/src"],
      "@/components/*": ["../core-ui/src/*"],
      "@/lib/compass-logic": ["../qbscript/src"],
      "@/lib/compass-logic/*": ["../qbscript/src/*"],
      "@/*": ["../core-engine/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
