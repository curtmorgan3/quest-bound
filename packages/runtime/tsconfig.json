{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "noEmit": true,
    "paths": {
      "@/pages/characters": ["./src/pages/characters"],
      "@/pages/characters/*": ["./src/pages/characters/*"],
      "@/pages/campaigns": ["./src/pages/campaigns"],
      "@/pages/campaigns/*": ["./src/pages/campaigns/*"],
      "@/pages/dice": ["./src/pages/dice"],
      "@/pages/dice/*": ["./src/pages/dice/*"],
      "@/pages/ruleset": ["../core-engine/src/pages/ruleset"],
      "@/pages/ruleset/*": ["../core-engine/src/pages/ruleset/*"],
      "@/lib/campaign-play": ["./src"],
      "@/lib/campaign-play/*": ["./src/*"],
      "@/lib/compass-api/hooks": ["../local-db/src/api-hooks"],
      "@/lib/compass-api/hooks/*": ["../local-db/src/api-hooks/*"],
      "@/lib/cloud": ["../cloud/src"],
      "@/lib/cloud/*": ["../cloud/src/*"],
      "@/components": ["../core-ui/src"],
      "@/components/*": ["../core-ui/src/*"],
      "@/lib/compass-logic": ["../qbscript/src"],
      "@/lib/compass-logic/*": ["../qbscript/src/*"],
      "@/*": ["../core-engine/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
