      "default": "./src/db.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@quest-bound/cloud": "2.1.74",
    "@quest-bound/types": "2.1.74",
    "dexie": "^4.2.0"
