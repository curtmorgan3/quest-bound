{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "noEmit": true,
    "paths": {
      "@/components": ["../core-ui/src"],
      "@/components/*": ["../core-ui/src/*"],
      "@/lib/compass-logic": ["../qbscript/src"],
      "@/lib/compass-logic/*": ["../qbscript/src/*"],
      "@/lib/cloud": ["../cloud/src"],
      "@/lib/cloud/*": ["../cloud/src/*"],
      "@/*": ["../../src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
