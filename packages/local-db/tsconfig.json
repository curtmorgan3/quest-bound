{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "noEmit": true,
    "paths": {
      "@/components": ["../core-ui/src"],
      "@/components/*": ["../core-ui/src/*"],
      "@/lib/compass-logic": ["../qbscript/src"],
      "@/lib/compass-logic/*": ["../qbscript/src/*"],
      "@/lib/cloud": ["../cloud/src"],
      "@/lib/cloud/*": ["../cloud/src/*"],
      "@/lib/campaign-play": ["../runtime/src"],
      "@/lib/campaign-play/*": ["../runtime/src/*"],
      "@/lib/compass-api/hooks": ["./src/api-hooks"],
      "@/lib/compass-api/hooks/*": ["./src/api-hooks/*"],
      "@/*": ["../core-engine/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/vite-env.d.ts"]
}
